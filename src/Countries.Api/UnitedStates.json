{
  "NewsApiCrawler": {
    "Name": "United States",
    "Enabled": true,
    "Providers": [
      {
        "Name": "NewsApiOrg",
        "Enabled": true,
        "Cron": "17 3 * * *",
        "BaseUrl": "https://newsapi.org/v2",
        "AuthType": "QueryParameter",
        "AuthParamName": "apiKey",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Everything",
            "Endpoint": "everything",
            "QueryParameters": {
              "q": "United States politics",
              "language": "en",
              "sortBy": "publishedAt",
              "pageSize": "50"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          },
          {
            "Name": "TopHeadlines",
            "Endpoint": "top-headlines",
            "QueryParameters": {
              "category": "general",
              "country": "us",
              "pageSize": "50"
            },
            "Category": "General",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "GNews",
        "Enabled": true,
        "Cron": "23 4 * * *",
        "BaseUrl": "https://gnews.io/api/v4",
        "AuthType": "QueryParameter",
        "AuthParamName": "apikey",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Search",
            "Endpoint": "search",
            "QueryParameters": {
              "q": "United States politics",
              "lang": "en",
              "country": "us",
              "max": "10"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "NewsDataIo",
        "Enabled": true,
        "Cron": "31 5 * * *",
        "BaseUrl": "https://newsdata.io/api/1",
        "AuthType": "QueryParameter",
        "AuthParamName": "apikey",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Latest",
            "Endpoint": "latest",
            "QueryParameters": {
              "q": "United States politics",
              "country": "us",
              "language": "en",
              "category": "politics"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "EventRegistry",
        "Enabled": true,
        "Cron": "42 6 * * *",
        "BaseUrl": "https://eventregistry.org/api/v1/article/getArticles",
        "AuthType": "QueryParameter",
        "AuthParamName": "apiKey (ignored - EventRegistryProvider is a custom implementation that puts the key in the POST body itself, still read from NewsApiKeys:EventRegistry)",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "GetArticles",
            "Endpoint": "",
            "QueryParameters": {
              "keyword": "United States politics",
              "lang": "eng"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "GDELT",
        "Enabled": true,
        "Cron": "8 * * * *",
        "BaseUrl": "https://api.gdeltproject.org/api/v2/doc",
        "AuthType": "None",
        "AuthParamName": "",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "DocSearch",
            "Endpoint": "doc",
            "QueryParameters": {
              "query": "United States politics sourcecountry:US",
              "mode": "artlist",
              "format": "json",
              "maxrecords": "75"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "FEC",
        "Enabled": true,
        "Cron": "3 * * * *",
        "BaseUrl": "https://api.open.fec.gov/v1",
        "AuthType": "QueryParameter",
        "AuthParamName": "api_key",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Candidates",
            "Endpoint": "candidates/",
            "QueryParameters": {
              "sort": "-first_file_date",
              "per_page": "20"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "CongressGov",
        "Enabled": true,
        "Cron": "11 * * * *",
        "BaseUrl": "https://api.congress.gov/v3",
        "AuthType": "QueryParameter",
        "AuthParamName": "api_key",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Bills",
            "Endpoint": "bill",
            "QueryParameters": {
              "sort": "updateDate+desc",
              "limit": "20"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "APContentAPI",
        "Enabled": true,
        "Cron": "19 * * * *",
        "BaseUrl": "https://api.ap.org/media/v",
        "AuthType": "QueryParameter",
        "AuthParamName": "apikey",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Search",
            "Endpoint": "content/search",
            "QueryParameters": {
              "q": "election",
              "page_size": "20"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "NYTimesAPI",
        "Enabled": true,
        "Cron": "27 * * * *",
        "BaseUrl": "https://api.nytimes.com/svc/topstories/v2",
        "AuthType": "QueryParameter",
        "AuthParamName": "api-key",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "Politics",
            "Endpoint": "politics.json",
            "QueryParameters": {},
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "ProPublicaCongress",
        "Enabled": true,
        "Cron": "35 * * * *",
        "BaseUrl": "https://api.propublica.org/congress/v1",
        "AuthType": "HttpHeader",
        "AuthParamName": "X-API-Key",
        "TimeoutSeconds": 120,
        "Endpoints": [
          {
            "Name": "RecentBills",
            "Endpoint": "118/both/bills/introduced.json",
            "QueryParameters": {},
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      }
    ]
  }
}
