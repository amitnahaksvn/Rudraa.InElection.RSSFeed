{
  "NewsApiCrawler": {
    "Name": "Australia",
    "Enabled": true,
    "Providers": [
      {
        "Name": "NewsApiOrg",
        "Enabled": true,
        "Cron": "17 3 * * *",
        "BaseUrl": "https://newsapi.org/v2",
        "AuthType": "QueryParameter",
        "AuthParamName": "apiKey",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "Everything",
            "Endpoint": "everything",
            "QueryParameters": {
              "q": "Australia politics",
              "language": "en",
              "sortBy": "publishedAt",
              "pageSize": "50"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          },
          {
            "Name": "TopHeadlines",
            "Endpoint": "top-headlines",
            "QueryParameters": {
              "category": "general",
              "country": "au",
              "pageSize": "50"
            },
            "Category": "General",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "GNews",
        "Enabled": true,
        "Cron": "23 4 * * *",
        "BaseUrl": "https://gnews.io/api/v4",
        "AuthType": "QueryParameter",
        "AuthParamName": "apikey",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "Search",
            "Endpoint": "search",
            "QueryParameters": {
              "q": "Australia politics",
              "lang": "en",
              "country": "au",
              "max": "10"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          },
          {
            "Name": "TopHeadlines",
            "Endpoint": "top-headlines",
            "QueryParameters": {
              "category": "nation",
              "lang": "en",
              "country": "au",
              "max": "10"
            },
            "Category": "General",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "TheNewsAPI",
        "Enabled": true,
        "Cron": "9 7 * * *",
        "BaseUrl": "https://api.thenewsapi.com/v1/news",
        "AuthType": "QueryParameter",
        "AuthParamName": "api_token",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "All",
            "Endpoint": "all",
            "QueryParameters": {
              "search": "Australia politics",
              "language": "en",
              "categories": "politics",
              "limit": "25"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          },
          {
            "Name": "Top",
            "Endpoint": "top",
            "QueryParameters": {
              "locale": "au",
              "language": "en",
              "limit": "25"
            },
            "Category": "General",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "CurrentsAPI",
        "Enabled": true,
        "Cron": "37 */2 * * *",
        "BaseUrl": "https://api.currentsapi.services/v1",
        "AuthType": "QueryParameter",
        "AuthParamName": "apiKey",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "LatestNews",
            "Endpoint": "latest-news",
            "QueryParameters": {
              "language": "en",
              "category": "politics",
              "keywords": "Australia politics"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          },
          {
            "Name": "Search",
            "Endpoint": "search",
            "QueryParameters": {
              "language": "en",
              "country": "AU",
              "keywords": "Australia politics"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "Mediastack",
        "Enabled": true,
        "Cron": "5 9 */2 * *",
        "BaseUrl": "http://api.mediastack.com/v1",
        "AuthType": "QueryParameter",
        "AuthParamName": "access_key",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "News",
            "Endpoint": "news",
            "QueryParameters": {
              "keywords": "Australia politics",
              "languages": "en",
              "countries": "au",
              "categories": "general",
              "limit": "25"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "NewsDataIo",
        "Enabled": true,
        "Cron": "31 5 * * *",
        "BaseUrl": "https://newsdata.io/api/1",
        "AuthType": "QueryParameter",
        "AuthParamName": "apikey",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "Latest",
            "Endpoint": "latest",
            "QueryParameters": {
              "q": "Australia politics",
              "country": "au",
              "language": "en",
              "category": "politics"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "WorldNewsAPI",
        "Enabled": false,
        "Cron": "12 */6 * * *",
        "BaseUrl": "https://api.worldnewsapi.com",
        "AuthType": "HttpHeader",
        "AuthParamName": "x-api-key",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "SearchNews",
            "Endpoint": "search-news",
            "QueryParameters": {
              "text": "Australia politics",
              "language": "en",
              "source-countries": "au",
              "number": "25"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          },
          {
            "Name": "TopNews",
            "Endpoint": "top-news",
            "QueryParameters": {
              "source-country": "au",
              "language": "en"
            },
            "Category": "General",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "EventRegistry",
        "Enabled": true,
        "Cron": "42 6 * * *",
        "BaseUrl": "https://eventregistry.org/api/v1/article/getArticles",
        "AuthType": "QueryParameter",
        "AuthParamName": "apiKey (ignored - EventRegistryProvider is a custom implementation that puts the key in the POST body itself, still read from NewsApiKeys:EventRegistry)",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "GetArticles",
            "Endpoint": "",
            "QueryParameters": {
              "keyword": "Australia politics",
              "lang": "eng"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "GDELT",
        "Enabled": true,
        "Cron": "8 * * * *",
        "BaseUrl": "https://api.gdeltproject.org/api/v2/doc",
        "AuthType": "None",
        "AuthParamName": "",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "DocSearch",
            "Endpoint": "doc",
            "QueryParameters": {
              "query": "Australia politics sourcecountry:AS",
              "mode": "artlist",
              "format": "json",
              "maxrecords": "75"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      },
      {
        "Name": "SerpApiGoogleNews",
        "Enabled": true,
        "Cron": "54 8 * * *",
        "BaseUrl": "https://serpapi.com",
        "AuthType": "QueryParameter",
        "AuthParamName": "api_key",
        "TimeoutSeconds": 30,
        "Endpoints": [
          {
            "Name": "GoogleNews",
            "Endpoint": "search.json",
            "QueryParameters": {
              "engine": "google_news",
              "q": "Australia politics",
              "gl": "au",
              "hl": "en"
            },
            "Category": "Politics",
            "Language": "en",
            "Enabled": true
          }
        ]
      }
    ]
  }
}
